Terminals unused in grammar

    ITEM


Grammar

    0 $accept: translation_unit $end

    1 primary_expression: IDENTIFIER
    2                   | constant
    3                   | string
    4                   | '(' expression ')'
    5                   | generic_selection

    6 constant: I_CONSTANT
    7         | F_CONSTANT
    8         | ENUMERATION_CONSTANT

    9 enumeration_constant: IDENTIFIER

   10 string: STRING_LITERAL
   11       | FUNC_NAME

   12 generic_selection: GENERIC '(' assignment_expression ',' generic_assoc_list ')'

   13 generic_assoc_list: generic_association
   14                   | generic_assoc_list ',' generic_association

   15 generic_association: type_name ':' assignment_expression
   16                    | DEFAULT ':' assignment_expression

   17 slice_item: assignment_expression
   18           | ':'

   19 slice_expression: slice_item
   20                 | slice_expression ',' slice_item

   21 postfix_expression: primary_expression
   22                   | postfix_expression '[' slice_expression ']'
   23                   | postfix_expression '(' ')'
   24                   | postfix_expression '(' argument_expression_list ')'
   25                   | postfix_expression '.' IDENTIFIER
   26                   | postfix_expression PTR_OP IDENTIFIER
   27                   | postfix_expression INC_OP
   28                   | postfix_expression DEC_OP
   29                   | '(' type_name ')' '{' initializer_list '}'
   30                   | '(' type_name ')' '{' initializer_list ',' '}'

   31 argument_expression_list: assignment_expression
   32                         | argument_expression_list ',' assignment_expression

   33 unary_expression: postfix_expression
   34                 | INC_OP unary_expression
   35                 | DEC_OP unary_expression
   36                 | unary_operator cast_expression
   37                 | SIZEOF unary_expression
   38                 | SIZEOF '(' type_name ')'
   39                 | ALIGNOF '(' type_name ')'

   40 unary_operator: '&'
   41               | '*'
   42               | '+'
   43               | '-'
   44               | '~'
   45               | '!'

   46 cast_expression: unary_expression
   47                | '(' type_name ')' cast_expression

   48 multiplicative_expression: cast_expression
   49                          | multiplicative_expression '*' cast_expression
   50                          | multiplicative_expression '/' cast_expression
   51                          | multiplicative_expression '%' cast_expression
   52                          | multiplicative_expression DOT_MUL cast_expression
   53                          | multiplicative_expression DOT_DIV cast_expression
   54                          | multiplicative_expression AT cast_expression
   55                          | multiplicative_expression AT_MUL cast_expression

   56 additive_expression: multiplicative_expression
   57                    | additive_expression '+' multiplicative_expression
   58                    | additive_expression '-' multiplicative_expression
   59                    | additive_expression DOT_ADD multiplicative_expression
   60                    | additive_expression DOT_SUB multiplicative_expression

   61 shift_expression: additive_expression
   62                 | shift_expression LEFT_OP additive_expression
   63                 | shift_expression RIGHT_OP additive_expression

   64 relational_expression: shift_expression
   65                      | relational_expression '<' shift_expression
   66                      | relational_expression '>' shift_expression
   67                      | relational_expression LE_OP shift_expression
   68                      | relational_expression GE_OP shift_expression
   69                      | relational_expression TH_OP shift_expression

   70 equality_expression: relational_expression
   71                    | equality_expression EQ_OP relational_expression
   72                    | equality_expression NE_OP relational_expression

   73 and_expression: equality_expression
   74               | and_expression '&' equality_expression

   75 exclusive_or_expression: and_expression
   76                        | exclusive_or_expression '^' and_expression

   77 inclusive_or_expression: exclusive_or_expression
   78                        | inclusive_or_expression '|' exclusive_or_expression

   79 logical_and_expression: inclusive_or_expression
   80                       | logical_and_expression AND_OP inclusive_or_expression

   81 logical_or_expression: logical_and_expression
   82                      | logical_or_expression OR_OP logical_and_expression

   83 conditional_expression: logical_or_expression

   84 assignment_expression: conditional_expression
   85                      | unary_expression assignment_operator assignment_expression

   86 assignment_operator: '='
   87                    | MUL_ASSIGN
   88                    | DIV_ASSIGN
   89                    | MOD_ASSIGN
   90                    | ADD_ASSIGN
   91                    | SUB_ASSIGN
   92                    | LEFT_ASSIGN
   93                    | RIGHT_ASSIGN
   94                    | AND_ASSIGN
   95                    | XOR_ASSIGN
   96                    | OR_ASSIGN

   97 expression: assignment_expression
   98           | expression ',' assignment_expression

   99 constant_expression: conditional_expression

  100 declaration: declaration_specifiers ';'
  101            | declaration_specifiers init_declarator_list ';'
  102            | static_assert_declaration

  103 declaration_specifiers: storage_class_specifier declaration_specifiers
  104                       | storage_class_specifier
  105                       | type_specifier declaration_specifiers
  106                       | type_specifier
  107                       | type_qualifier declaration_specifiers
  108                       | type_qualifier
  109                       | function_specifier declaration_specifiers
  110                       | function_specifier
  111                       | alignment_specifier declaration_specifiers
  112                       | alignment_specifier

  113 init_declarator_list: init_declarator
  114                     | init_declarator_list ',' init_declarator

  115 init_declarator: declarator '=' initializer
  116                | declarator

  117 storage_class_specifier: TYPEDEF
  118                        | EXTERN
  119                        | STATIC
  120                        | THREAD_LOCAL
  121                        | AUTO
  122                        | REGISTER

  123 type_specifier: VOID
  124               | CHAR
  125               | SHORT
  126               | INT
  127               | LONG
  128               | FP
  129               | DOUBLE
  130               | SIGNED
  131               | UNSIGNED
  132               | TEXT
  133               | tensor_type
  134               | BOOL
  135               | COMPLEX
  136               | IMAGINARY
  137               | struct_or_union_specifier
  138               | enum_specifier
  139               | TYPEDEF_NAME

  140 tensor_type: TENSOR '<' tensor_params '>'

  141 tensor_params: type_specifier ',' dimension_list

  142 loop_label: BACKTICK IDENTIFIER ':'

  143 struct_or_union_specifier: struct_or_union '{' struct_declaration_list '}'
  144                          | struct_or_union IDENTIFIER '{' struct_declaration_list '}'
  145                          | struct_or_union IDENTIFIER

  146 struct_or_union: STRUCT
  147                | UNION

  148 struct_declaration_list: struct_declaration
  149                        | struct_declaration_list struct_declaration

  150 struct_declaration: specifier_qualifier_list ';'
  151                   | specifier_qualifier_list struct_declarator_list ';'
  152                   | static_assert_declaration

  153 specifier_qualifier_list: type_specifier specifier_qualifier_list
  154                         | type_specifier
  155                         | type_qualifier specifier_qualifier_list
  156                         | type_qualifier

  157 struct_declarator_list: struct_declarator
  158                       | struct_declarator_list ',' struct_declarator

  159 struct_declarator: ':' constant_expression
  160                  | declarator ':' constant_expression
  161                  | declarator '=' initializer
  162                  | declarator

  163 enum_specifier: ENUM '{' enumerator_list '}'
  164               | ENUM '{' enumerator_list ',' '}'
  165               | ENUM IDENTIFIER '{' enumerator_list '}'
  166               | ENUM IDENTIFIER '{' enumerator_list ',' '}'
  167               | ENUM IDENTIFIER

  168 enumerator_list: enumerator
  169                | enumerator_list ',' enumerator

  170 enumerator: enumeration_constant '=' constant_expression
  171           | enumeration_constant

  172 type_qualifier: CONST
  173               | RESTRICT
  174               | VOLATILE
  175               | ATOMIC

  176 function_specifier: INLINE
  177                   | NORETURN

  178 alignment_specifier: ALIGNAS '(' type_name ')'
  179                    | ALIGNAS '(' constant_expression ')'

  180 declarator: pointer direct_declarator
  181           | direct_declarator

  182 direct_declarator: IDENTIFIER
  183                  | '(' declarator ')'
  184                  | direct_declarator '[' ']'
  185                  | direct_declarator '[' '*' ']'
  186                  | direct_declarator '[' STATIC type_qualifier_list assignment_expression ']'
  187                  | direct_declarator '[' STATIC assignment_expression ']'
  188                  | direct_declarator '[' type_qualifier_list '*' ']'
  189                  | direct_declarator '[' type_qualifier_list STATIC assignment_expression ']'
  190                  | direct_declarator '[' type_qualifier_list assignment_expression ']'
  191                  | direct_declarator '[' type_qualifier_list ']'
  192                  | direct_declarator '[' assignment_expression ']'
  193                  | direct_declarator '(' parameter_type_list ')'
  194                  | direct_declarator '(' ')'
  195                  | direct_declarator '(' identifier_list ')'

  196 pointer: '*' type_qualifier_list pointer
  197        | '*' type_qualifier_list
  198        | '*' pointer
  199        | '*'

  200 type_qualifier_list: type_qualifier
  201                    | type_qualifier_list type_qualifier

  202 parameter_type_list: parameter_list ',' ELLIPSIS
  203                    | parameter_list

  204 parameter_list: parameter_declaration
  205               | parameter_list ',' parameter_declaration

  206 parameter_declaration: declaration_specifiers declarator
  207                      | declaration_specifiers abstract_declarator
  208                      | declaration_specifiers

  209 identifier_list: IDENTIFIER
  210                | identifier_list ',' IDENTIFIER

  211 type_name: specifier_qualifier_list abstract_declarator
  212          | specifier_qualifier_list

  213 abstract_declarator: pointer direct_abstract_declarator
  214                    | pointer
  215                    | direct_abstract_declarator

  216 direct_abstract_declarator: '(' abstract_declarator ')'
  217                           | '[' ']'
  218                           | '[' '*' ']'
  219                           | '[' STATIC type_qualifier_list assignment_expression ']'
  220                           | '[' STATIC assignment_expression ']'
  221                           | '[' type_qualifier_list STATIC assignment_expression ']'
  222                           | '[' type_qualifier_list assignment_expression ']'
  223                           | '[' type_qualifier_list ']'
  224                           | '[' assignment_expression ']'
  225                           | direct_abstract_declarator '[' ']'
  226                           | direct_abstract_declarator '[' '*' ']'
  227                           | direct_abstract_declarator '[' STATIC type_qualifier_list assignment_expression ']'
  228                           | direct_abstract_declarator '[' STATIC assignment_expression ']'
  229                           | direct_abstract_declarator '[' type_qualifier_list assignment_expression ']'
  230                           | direct_abstract_declarator '[' type_qualifier_list STATIC assignment_expression ']'
  231                           | direct_abstract_declarator '[' type_qualifier_list ']'
  232                           | direct_abstract_declarator '[' assignment_expression ']'
  233                           | '(' ')'
  234                           | '(' parameter_type_list ')'
  235                           | direct_abstract_declarator '(' ')'
  236                           | direct_abstract_declarator '(' parameter_type_list ')'

  237 initializer: '{' initializer_list '}'
  238            | '{' initializer_list ',' '}'
  239            | assignment_expression

  240 initializer_list: designation initializer
  241                 | initializer
  242                 | initializer_list ',' designation initializer
  243                 | initializer_list ',' initializer

  244 designation: designator_list '='

  245 designator_list: designator
  246                | designator_list designator

  247 designator: '[' constant_expression ']'
  248           | '.' IDENTIFIER

  249 static_assert_declaration: STATIC_ASSERT '(' constant_expression ',' STRING_LITERAL ')' ';'

  250 statement: labeled_statement
  251          | compound_statement
  252          | expression_statement
  253          | selection_statement
  254          | iteration_statement
  255          | jump_statement

  256 labeled_statement: IDENTIFIER ':' statement
  257                  | CASE constant_expression ':' statement
  258                  | DEFAULT ':' statement

  259 compound_statement: '{' '}'

  260 $@1: ε

  261 compound_statement: '{' $@1 block_item_list '}'

  262 block_item_list: block_item
  263                | block_item_list block_item

  264 block_item: declaration
  265           | statement

  266 expression_statement: ';'
  267                     | expression ';'

  268 if_cond: ε

  269 @2: ε

  270 selection_statement: IF '(' expression ')' if_cond compound_statement ELSE @2 compound_statement

  271 @3: ε

  272 selection_statement: IF '(' expression ')' if_cond compound_statement ELSE @3 selection_statement
  273                    | IF '(' expression ')' if_cond compound_statement
  274                    | SWITCH '(' expression ')' compound_statement

  275 for_init: ';'
  276         | expression ';'
  277         | declaration

  278 for_cond_expr: ';'
  279              | expression ';'

  280 $@4: ε

  281 @5: ε

  282 @6: ε

  283 loop_statement: WHILE $@4 @5 '(' expression ')' @6 compound_statement

  284 $@7: ε

  285 @8: ε

  286 loop_statement: DO $@7 @8 compound_statement WHILE '(' expression ')' ';'

  287 $@9: ε

  288 @10: ε

  289 @11: ε

  290 loop_statement: FOR $@9 '(' for_init @10 for_cond_expr @11 for_step ')' compound_statement
  291               | FOR IDENTIFIER IN IDENTIFIER axis_clause compound_statement

  292 for_step: ε
  293         | expression

  294 iteration_statement: loop_statement
  295                    | loop_label loop_statement

  296 axis_clause: ε
  297            | AXIS '(' axis_list ')'

  298 axis_list: I_CONSTANT
  299          | axis_list ',' I_CONSTANT

  300 dimension_list: I_CONSTANT
  301               | dimension_list ',' I_CONSTANT

  302 jump_statement: GOTO IDENTIFIER ';'
  303               | CONTINUE ';'
  304               | CONTINUE IDENTIFIER ';'
  305               | BREAK ';'
  306               | BREAK IDENTIFIER ';'
  307               | RETURN ';'
  308               | RETURN expression ';'

  309 translation_unit: external_declaration
  310                 | translation_unit external_declaration

  311 external_declaration: function_definition
  312                     | declaration

  313 function_definition: declaration_specifiers declarator declaration_list compound_statement
  314                    | declaration_specifiers declarator compound_statement

  315 declaration_list: declaration
  316                 | declaration_list declaration


