Grammar

    0 $accept: translation_unit $end

    1 primary_expression: IDENTIFIER
    2                   | constant
    3                   | string
    4                   | '(' expression ')'
    5                   | generic_selection

    6 constant: I_CONSTANT
    7         | F_CONSTANT
    8         | ENUMERATION_CONSTANT

    9 enumeration_constant: IDENTIFIER

   10 string: STRING_LITERAL
   11       | FUNC_NAME

   12 generic_selection: GENERIC '(' assignment_expression ',' generic_assoc_list ')'

   13 generic_assoc_list: generic_association
   14                   | generic_assoc_list ',' generic_association

   15 generic_association: type_name ':' assignment_expression
   16                    | DEFAULT ':' assignment_expression

   17 slice_item: assignment_expression
   18           | ':'

   19 slice_expression: slice_item
   20                 | slice_expression ',' slice_item

   21 postfix_expression: primary_expression
   22                   | postfix_expression '[' slice_expression ']'
   23                   | postfix_expression '(' ')'
   24                   | postfix_expression '(' argument_expression_list ')'
   25                   | postfix_expression '.' IDENTIFIER
   26                   | postfix_expression PTR_OP IDENTIFIER
   27                   | postfix_expression INC_OP
   28                   | postfix_expression DEC_OP
   29                   | '(' type_name ')' '{' initializer_list '}'
   30                   | '(' type_name ')' '{' initializer_list ',' '}'

   31 argument_expression_list: assignment_expression
   32                         | argument_expression_list ',' assignment_expression

   33 unary_expression: postfix_expression
   34                 | INC_OP unary_expression
   35                 | DEC_OP unary_expression
   36                 | unary_operator cast_expression
   37                 | SIZEOF unary_expression
   38                 | SIZEOF '(' type_name ')'
   39                 | ALIGNOF '(' type_name ')'

   40 unary_operator: '&'
   41               | '*'
   42               | '+'
   43               | '-'
   44               | '~'
   45               | '!'

   46 cast_expression: unary_expression
   47                | '(' type_name ')' cast_expression

   48 multiplicative_expression: cast_expression
   49                          | multiplicative_expression '*' cast_expression
   50                          | multiplicative_expression '/' cast_expression
   51                          | multiplicative_expression '%' cast_expression
   52                          | multiplicative_expression DOT_MUL cast_expression
   53                          | multiplicative_expression DOT_DIV cast_expression
   54                          | multiplicative_expression AT cast_expression
   55                          | multiplicative_expression AT_MUL cast_expression

   56 additive_expression: multiplicative_expression
   57                    | additive_expression '+' multiplicative_expression
   58                    | additive_expression '-' multiplicative_expression
   59                    | additive_expression DOT_ADD multiplicative_expression
   60                    | additive_expression DOT_SUB multiplicative_expression

   61 shift_expression: additive_expression
   62                 | shift_expression LEFT_OP additive_expression
   63                 | shift_expression RIGHT_OP additive_expression

   64 relational_expression: shift_expression
   65                      | relational_expression '<' shift_expression
   66                      | relational_expression '>' shift_expression
   67                      | relational_expression LE_OP shift_expression
   68                      | relational_expression GE_OP shift_expression
   69                      | relational_expression TH_OP shift_expression

   70 equality_expression: relational_expression
   71                    | equality_expression EQ_OP relational_expression
   72                    | equality_expression NE_OP relational_expression

   73 and_expression: equality_expression
   74               | and_expression '&' equality_expression

   75 exclusive_or_expression: and_expression
   76                        | exclusive_or_expression '^' and_expression

   77 inclusive_or_expression: exclusive_or_expression
   78                        | inclusive_or_expression '|' exclusive_or_expression

   79 logical_and_expression: inclusive_or_expression
   80                       | logical_and_expression AND_OP inclusive_or_expression

   81 logical_or_expression: logical_and_expression
   82                      | logical_or_expression OR_OP logical_and_expression

   83 conditional_expression: logical_or_expression

   84 assignment_expression: conditional_expression
   85                      | unary_expression assignment_operator assignment_expression

   86 assignment_operator: '='
   87                    | MUL_ASSIGN
   88                    | DIV_ASSIGN
   89                    | MOD_ASSIGN
   90                    | ADD_ASSIGN
   91                    | SUB_ASSIGN
   92                    | LEFT_ASSIGN
   93                    | RIGHT_ASSIGN
   94                    | AND_ASSIGN
   95                    | XOR_ASSIGN
   96                    | OR_ASSIGN

   97 expression: assignment_expression
   98           | expression ',' assignment_expression

   99 constant_expression: conditional_expression

  100 declaration: declaration_specifiers ';'
  101            | declaration_specifiers init_declarator_list ';'
  102            | static_assert_declaration

  103 declaration_specifiers: storage_class_specifier declaration_specifiers
  104                       | storage_class_specifier
  105                       | type_specifier declaration_specifiers
  106                       | type_specifier
  107                       | type_qualifier declaration_specifiers
  108                       | type_qualifier
  109                       | function_specifier declaration_specifiers
  110                       | function_specifier
  111                       | alignment_specifier declaration_specifiers
  112                       | alignment_specifier

  113 init_declarator_list: init_declarator
  114                     | init_declarator_list ',' init_declarator

  115 init_declarator: declarator '=' initializer
  116                | declarator

  117 storage_class_specifier: TYPEDEF
  118                        | EXTERN
  119                        | STATIC
  120                        | THREAD_LOCAL
  121                        | AUTO
  122                        | REGISTER

  123 type_specifier: VOID
  124               | CHAR
  125               | SHORT
  126               | INT
  127               | LONG
  128               | FP
  129               | DOUBLE
  130               | SIGNED
  131               | UNSIGNED
  132               | TEXT
  133               | tensor_type
  134               | BOOL
  135               | COMPLEX
  136               | IMAGINARY
  137               | atomic_type_specifier
  138               | struct_or_union_specifier
  139               | enum_specifier
  140               | TYPEDEF_NAME

  141 tensor_type: TENSOR '<' tensor_params '>'

  142 tensor_params: type_specifier ',' dimension_list

  143 loop_label: BACKTICK IDENTIFIER ':'

  144 struct_or_union_specifier: struct_or_union '{' struct_declaration_list '}'
  145                          | struct_or_union IDENTIFIER '{' struct_declaration_list '}'
  146                          | struct_or_union IDENTIFIER

  147 struct_or_union: STRUCT
  148                | UNION

  149 struct_declaration_list: struct_declaration
  150                        | struct_declaration_list struct_declaration

  151 struct_declaration: specifier_qualifier_list ';'
  152                   | specifier_qualifier_list struct_declarator_list ';'
  153                   | static_assert_declaration

  154 specifier_qualifier_list: type_specifier specifier_qualifier_list
  155                         | type_specifier
  156                         | type_qualifier specifier_qualifier_list
  157                         | type_qualifier

  158 struct_declarator_list: struct_declarator
  159                       | struct_declarator_list ',' struct_declarator

  160 struct_declarator: ':' constant_expression
  161                  | declarator ':' constant_expression
  162                  | declarator '=' initializer
  163                  | declarator

  164 enum_specifier: ENUM '{' enumerator_list '}'
  165               | ENUM '{' enumerator_list ',' '}'
  166               | ENUM IDENTIFIER '{' enumerator_list '}'
  167               | ENUM IDENTIFIER '{' enumerator_list ',' '}'
  168               | ENUM IDENTIFIER

  169 enumerator_list: enumerator
  170                | enumerator_list ',' enumerator

  171 enumerator: enumeration_constant '=' constant_expression
  172           | enumeration_constant

  173 atomic_type_specifier: ATOMIC '(' type_name ')'

  174 type_qualifier: CONST
  175               | RESTRICT
  176               | VOLATILE
  177               | ATOMIC

  178 function_specifier: INLINE
  179                   | NORETURN

  180 alignment_specifier: ALIGNAS '(' type_name ')'
  181                    | ALIGNAS '(' constant_expression ')'

  182 $@1: ε

  183 declarator: pointer $@1 direct_declarator
  184           | direct_declarator

  185 direct_declarator: IDENTIFIER
  186                  | '(' declarator ')'
  187                  | direct_declarator '[' ']'
  188                  | direct_declarator '[' '*' ']'
  189                  | direct_declarator '[' STATIC type_qualifier_list assignment_expression ']'
  190                  | direct_declarator '[' STATIC assignment_expression ']'
  191                  | direct_declarator '[' type_qualifier_list '*' ']'
  192                  | direct_declarator '[' type_qualifier_list STATIC assignment_expression ']'
  193                  | direct_declarator '[' type_qualifier_list assignment_expression ']'
  194                  | direct_declarator '[' type_qualifier_list ']'
  195                  | direct_declarator '[' assignment_expression ']'
  196                  | direct_declarator '(' parameter_type_list ')'
  197                  | direct_declarator '(' ')'
  198                  | direct_declarator '(' identifier_list ')'

  199 pointer: '*' type_qualifier_list pointer
  200        | '*' type_qualifier_list
  201        | '*' pointer
  202        | '*'

  203 type_qualifier_list: type_qualifier
  204                    | type_qualifier_list type_qualifier

  205 parameter_type_list: parameter_list ',' ELLIPSIS
  206                    | parameter_list

  207 parameter_list: parameter_declaration
  208               | parameter_list ',' parameter_declaration
  209               | parameter_list ',' ELLIPSIS

  210 parameter_declaration: declaration_specifiers declarator
  211                      | declaration_specifiers abstract_declarator
  212                      | declaration_specifiers

  213 identifier_list: IDENTIFIER
  214                | identifier_list ',' IDENTIFIER

  215 type_name: specifier_qualifier_list abstract_declarator
  216          | specifier_qualifier_list

  217 abstract_declarator: pointer direct_abstract_declarator
  218                    | pointer
  219                    | direct_abstract_declarator

  220 direct_abstract_declarator: '(' abstract_declarator ')'
  221                           | '[' ']'
  222                           | '[' '*' ']'
  223                           | '[' STATIC type_qualifier_list assignment_expression ']'
  224                           | '[' STATIC assignment_expression ']'
  225                           | '[' type_qualifier_list STATIC assignment_expression ']'
  226                           | '[' type_qualifier_list assignment_expression ']'
  227                           | '[' type_qualifier_list ']'
  228                           | '[' assignment_expression ']'
  229                           | direct_abstract_declarator '[' ']'
  230                           | direct_abstract_declarator '[' '*' ']'
  231                           | direct_abstract_declarator '[' STATIC type_qualifier_list assignment_expression ']'
  232                           | direct_abstract_declarator '[' STATIC assignment_expression ']'
  233                           | direct_abstract_declarator '[' type_qualifier_list assignment_expression ']'
  234                           | direct_abstract_declarator '[' type_qualifier_list STATIC assignment_expression ']'
  235                           | direct_abstract_declarator '[' type_qualifier_list ']'
  236                           | direct_abstract_declarator '[' assignment_expression ']'
  237                           | '(' ')'
  238                           | '(' parameter_type_list ')'
  239                           | direct_abstract_declarator '(' ')'
  240                           | direct_abstract_declarator '(' parameter_type_list ')'

  241 initializer: '{' initializer_list '}'
  242            | '{' initializer_list ',' '}'
  243            | assignment_expression

  244 initializer_list: designation initializer
  245                 | initializer
  246                 | initializer_list ',' designation initializer
  247                 | initializer_list ',' initializer

  248 designation: designator_list '='

  249 designator_list: designator
  250                | designator_list designator

  251 designator: '[' constant_expression ']'
  252           | '.' IDENTIFIER

  253 static_assert_declaration: STATIC_ASSERT '(' constant_expression ',' STRING_LITERAL ')' ';'

  254 statement: labeled_statement
  255          | compound_statement
  256          | expression_statement
  257          | selection_statement
  258          | iteration_statement
  259          | jump_statement

  260 labeled_statement: IDENTIFIER ':' statement
  261                  | CASE constant_expression ':' statement
  262                  | DEFAULT ':' statement

  263 compound_statement: '{' '}'
  264                   | '{' block_item_list '}'

  265 block_item_list: block_item
  266                | block_item_list block_item

  267 block_item: declaration
  268           | statement

  269 expression_statement: ';'
  270                     | expression ';'

  271 $@2: ε

  272 selection_statement: IF '(' expression ')' statement ELSE $@2 statement
  273                    | IF '(' expression ')' statement
  274                    | SWITCH '(' expression ')' statement

  275 loop_statement: WHILE '(' expression ')' statement
  276               | DO statement WHILE '(' expression ')' ';'
  277               | FOR '(' expression_statement expression_statement ')' statement
  278               | FOR '(' expression_statement expression_statement expression ')' statement
  279               | FOR '(' declaration expression_statement ')' statement
  280               | FOR '(' declaration expression_statement expression ')' statement
  281               | FOR IDENTIFIER IN IDENTIFIER axis_clause compound_statement

  282 iteration_statement: loop_statement
  283                    | loop_label loop_statement

  284 axis_clause: ε
  285            | AXIS '(' axis_list ')'

  286 axis_list: I_CONSTANT
  287          | axis_list ',' I_CONSTANT

  288 dimension_list: I_CONSTANT
  289               | dimension_list ',' I_CONSTANT

  290 jump_statement: GOTO IDENTIFIER ';'
  291               | CONTINUE ';'
  292               | CONTINUE IDENTIFIER ';'
  293               | BREAK ';'
  294               | BREAK IDENTIFIER ';'
  295               | RETURN ';'
  296               | RETURN expression ';'

  297 translation_unit: external_declaration
  298                 | translation_unit external_declaration

  299 external_declaration: function_definition
  300                     | declaration

  301 function_definition: declaration_specifiers declarator declaration_list compound_statement
  302                    | declaration_specifiers declarator compound_statement

  303 declaration_list: declaration
  304                 | declaration_list declaration


